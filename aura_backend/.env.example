# Server
AURA_HOST=127.0.0.1
AURA_PORT=5000
AURA_DEBUG=false

# Serial
AURA_SERIAL_ENABLED=true
AURA_SERIAL_PORT=COM11
AURA_BAUD_RATE=115200
AURA_SERIAL_TIMEOUT_SEC=0.05
AURA_SERIAL_RECONNECT_SEC=2.0
AURA_SCAN_COOLDOWN_SEC=1.5
AURA_SERIAL_QUEUE_MAX_SIZE=256
AURA_SERIAL_POLL_SLEEP_SEC=0.01

# Story trigger threshold
AURA_CARDS_NEEDED=3

# Gemini
GEMINI_API_KEY=
# Use a model that supports generateContent in your account.
# Recommended: gemini-2.5-flash
AURA_GEMINI_MODEL=gemini-2.5-flash
AURA_GEMINI_TEMPERATURE=0.7
AURA_STORY_SEED_FILE=../prompt_v2/story_seeds.json

# Dummy mode (skip Gemini and use cached phase text)
AURA_DUMMY_MODE=false
AURA_DUMMY_CACHE_FILE=data/dummy_phase_cache.json

# Text to speech
AURA_TTS_ENABLED=true
AURA_TTS_CACHE_DIR=tts_cache
AURA_TTS_LANG=en
AURA_TTS_GAIN_DB=15.0

# Microphone capture (laptop mic)
AURA_MIC_ENABLED=true
AURA_MIC_TIMEOUT_SEC=30.0
AURA_MIC_PHRASE_LIMIT_SEC=8.0
AURA_MIC_AMBIENT_ADJUST_SEC=0.35

# Data
AURA_TAG_MAPPING_FILE=data/tag_mappings.json
AURA_LEGACY_MAPPING_ENABLED=true
AURA_LEGACY_MAPPING_PY=../Story_Reader.py
